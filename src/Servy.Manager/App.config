<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <add key="DesktopAppPublishPath" value=".\Servy.exe" />
    <add key="RefreshIntervalInSeconds" value="4" />
    <add key="PerformanceRefreshIntervalInMs" value="800" />
    <add key="ConsoleRefreshIntervalInMs" value="800" />
    <add key="ConsoleMaxLines" value="20000" />
    <add key="DependenciesRefreshIntervalInMs" value="800" />
    <add key="SearchDebounceDelayMs" value="300" />
    <add key="MaxBulkOperationParallelism" value="8" />
    <add key="LogsWindowDays" value="3" />
    
    <add key="LogLevel" value="INFO" />
    <add key="LogRotationSizeMB" value="10" />
    <add key="LogRollingInterval" value="NONE" />
    <add key="MaxBackupLogFiles" value="10" />
    <add key="UseLocalTimeForRotation" value="false" />
    <add key="EnableEventLog" value="true" />
  </appSettings>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="System.Threading.Tasks.Extensions" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-4.2.4.0" newVersion="4.2.4.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Microsoft.Bcl.AsyncInterfaces" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-10.0.0.10" newVersion="10.0.0.10" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>