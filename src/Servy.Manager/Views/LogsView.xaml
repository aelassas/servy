<UserControl
    x:Class="Servy.Manager.Views.LogsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Servy.Manager"
    xmlns:resx="clr-namespace:Servy.Manager.Resources"
    xmlns:viewmodels="clr-namespace:Servy.Manager.ViewModels"
    xmlns:converters="clr-namespace:Servy.Manager.Converters"
    mc:Ignorable="d"
    AutomationProperties.Name="Logs View"
    AutomationProperties.AutomationId="LogsView"
    AutomationProperties.HelpText="Displays a list of system events and diagnostic records for services.">

    <UserControl.Resources>
        <converters:MessageConverter x:Key="MessageConverter" />
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="180" />
            <RowDefinition Height="5" />
            <RowDefinition Height="0.25*" MinHeight="120" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            Orientation="Horizontal"
            Margin="0,0,0,10"
            Focusable="True"
            FocusVisualStyle="{x:Null}">

            <TextBlock
                Text="{x:Static resx:Strings.Label_Level}"
                VerticalAlignment="Center"
                Margin="0,0,5,0"
                AutomationProperties.Name="{x:Static resx:Strings.Label_Level}" />

            <ComboBox
                Width="120"
                SelectedItem="{Binding SelectedLevel, Mode=TwoWay}"
                ItemsSource="{Binding LogLevels}"
                Margin="0,0,10,0"
                AutomationProperties.Name="Filter by Level"
                AutomationProperties.AutomationId="LogsLevelComboBox" />

            <TextBlock
                Text="{x:Static resx:Strings.Label_From}"
                VerticalAlignment="Center"
                Margin="0,0,5,0"
                AutomationProperties.Name="{x:Static resx:Strings.Label_From}" />

            <DatePicker
                SelectedDate="{Binding FromDate, Mode=TwoWay}"
                DisplayDateEnd="{Binding FromDateMaxDate}"
                Width="150"
                Margin="0,0,10,0"
                AutomationProperties.Name="Filter from date"
                AutomationProperties.AutomationId="LogsFromDatePicker" />

            <TextBlock
                Text="{x:Static resx:Strings.Label_To}"
                VerticalAlignment="Center"
                Margin="0,0,5,0"
                AutomationProperties.Name="{x:Static resx:Strings.Label_To}" />

            <DatePicker
                SelectedDate="{Binding ToDate, Mode=TwoWay}"
                DisplayDateStart="{Binding ToDateMinDate}"
                Width="150"
                Margin="0,0,10,0"
                AutomationProperties.Name="Filter to date"
                AutomationProperties.AutomationId="LogsToDatePicker" />

            <TextBlock
                Text="{x:Static resx:Strings.Label_Keyword}"
                VerticalAlignment="Center"
                Margin="0,0,5,0"
                AutomationProperties.Name="{x:Static resx:Strings.Label_Keyword}" />

            <TextBox
                Text="{Binding Keyword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Width="200"
                Margin="0,0,10,0"
                VerticalContentAlignment="Center"
                AutomationProperties.Name="Filter by Keyword"
                AutomationProperties.AutomationId="LogsKeywordTextBox">

                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                </TextBox.InputBindings>
            </TextBox>

            <Button
                Content="{Binding SearchButtonText}"
                Command="{Binding SearchCommand}"
                Width="80"
                AutomationProperties.Name="{Binding SearchButtonText}"
                AutomationProperties.AutomationId="LogsSearchButton" />
        </StackPanel>

        <DataGrid
            x:Name="LogsDataGrid"
            Grid.Row="1"
            ItemsSource="{Binding LogsView, IsAsync=True}"
            SelectedItem="{Binding SelectedLog, Mode=TwoWay}"
            SelectionMode="Single"
            Margin="0,0,0,10"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            CanUserResizeRows="False"
            IsReadOnly="True"
            EnableRowVirtualization="True"
            EnableColumnVirtualization="True"
            VirtualizingStackPanel.IsVirtualizing="True"
            VirtualizingStackPanel.VirtualizationMode="Recycling"
            VirtualizingPanel.IsVirtualizingWhenGrouping="True"
            ScrollViewer.CanContentScroll="True"
            VirtualizingStackPanel.ScrollUnit="Pixel"
            AutomationProperties.Name="System Logs"
            AutomationProperties.AutomationId="LogsDataGrid">

            <DataGrid.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#0078D7" />
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#0078D7" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White" />
            </DataGrid.Resources>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Height" Value="26" />
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F5F5F5" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn
                    Header="{x:Static resx:Strings.Column_Time}"
                    Width="180"
                    MinWidth="180"
                    CanUserReorder="False"
                    CanUserResize="False"
                    SortMemberPath="Time">

                    <DataGridTemplateColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="AutomationProperties.Name" Value="Time" />
                        </Style>
                    </DataGridTemplateColumn.HeaderStyle>

                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                Text="{Binding Time}"
                                VerticalAlignment="Center"
                                Margin="5,0,0,0"
                                AutomationProperties.Name="{Binding Time}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    Header="{x:Static resx:Strings.Column_Level}"
                    Width="120"
                    MinWidth="120"
                    CanUserReorder="False"
                    CanUserResize="False"
                    SortMemberPath="Level">

                    <DataGridTemplateColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="AutomationProperties.Name" Value="Level" />
                        </Style>
                    </DataGridTemplateColumn.HeaderStyle>

                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="5,0,5,0">
                                <Image
                                    Source="{Binding LevelIcon}"
                                    Width="16"
                                    Height="16"
                                    Margin="0,0,5,0" />
                                <TextBlock
                                    Text="{Binding Level}"
                                    VerticalAlignment="Center"
                                    AutomationProperties.Name="{Binding Level}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn
                    Header="{x:Static resx:Strings.Column_Message}"
                    Width="*"
                    MinWidth="300"
                    CanUserReorder="False"
                    CanUserResize="False">

                    <DataGridTemplateColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="AutomationProperties.Name" Value="Message" />
                        </Style>
                    </DataGridTemplateColumn.HeaderStyle>

                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock
                                Text="{Binding Message, Converter={StaticResource MessageConverter}}"
                                VerticalAlignment="Center"
                                Margin="5,0,0,0"
                                TextWrapping="NoWrap"
                                TextTrimming="CharacterEllipsis"
                                AutomationProperties.Name="{Binding Message}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <GridSplitter
            Grid.Row="2"
            Height="5"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            Background="Gray"
            ShowsPreview="True"
            ResizeBehavior="PreviousAndNext" />

        <TextBox
            Grid.Row="3"
            Text="{Binding SelectedLogMessage}"
            Margin="0,5"
            IsReadOnly="True"
            TextWrapping="Wrap"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Auto"
            AutomationProperties.Name="Log Entry Details"
            AutomationProperties.AutomationId="LogDetailsTextBox" />

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                Margin="0,5,0,0"
                Text="{Binding FooterText}"
                Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                FontSize="12"
                TextWrapping="Wrap"
                HorizontalAlignment="Left"
                AutomationProperties.Name="{Binding FooterText}" />

            <TextBlock
                Grid.Row="0"
                Grid.Column="2"
                Margin="10,3,0,0"
                Text="{x:Static resx:Strings.Label_F5_Shortcut_Logs}"
                FontStyle="Normal"
                Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                TextWrapping="Wrap" />
        </Grid>
    </Grid>
</UserControl>