<UserControl
    x:Class="Servy.Manager.Views.ConsoleView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Servy.Manager"
    xmlns:resx="clr-namespace:Servy.Manager.Resources"
    xmlns:models="clr-namespace:Servy.Manager.Models"
    xmlns:viewmodels="clr-namespace:Servy.Manager.ViewModels"
    xmlns:converters="clr-namespace:Servy.UI.Converters;assembly=Servy.UI"
    xmlns:controls="clr-namespace:Servy.Manager.Views.Controls"
    mc:Ignorable="d"
    Loaded="UserControl_Loaded"
    AutomationProperties.Name="Console Output View"
    AutomationProperties.AutomationId="ConsoleViewRoot"
    AutomationProperties.HelpText="Displays real-time standard output and error logs for the selected service.">

    <UserControl.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="4*" />
        </Grid.ColumnDefinitions>

        <controls:ServiceListControl
            Grid.Column="0"
            Services="{Binding Services}"
            SelectedService="{Binding SelectedService}"
            SearchText="{Binding SearchText}"
            SearchButtonText="{Binding SearchButtonText}"
            SearchCommand="{Binding SearchCommand}"
            IsBusy="{Binding IsBusy}"
            AutomationProperties.Name="Service Selector"
            AutomationProperties.AutomationId="ConsoleServiceList"
            AutomationProperties.HelpText="Select a service to view its console output." />

        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Orientation="Horizontal"
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="0,0,0,6"
                    VerticalAlignment="Center">

                    <Border
                        Background="#F0F7FA"
                        CornerRadius="2"
                        Padding="4,0,0,0"
                        HorizontalAlignment="Left">

                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                Text="{x:Static resx:Strings.Label_Pid}"
                                Foreground="#1B7F9F"
                                FontSize="11"
                                VerticalAlignment="Center"
                                Margin="0,0,5,0" />

                            <TextBlock
                                Text="{Binding Pid}"
                                Foreground="#1B7F9F"
                                FontWeight="Bold"
                                FontSize="12"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Process ID"
                                AutomationProperties.AutomationId="ConsolePidValue" />

                            <Button
                                Command="{Binding CopyPidCommand}"
                                Margin="5,0,0,0"
                                Padding="4"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="{x:Static resx:Strings.Button_CopyPid}"
                                FocusVisualStyle="{x:Null}"
                                AutomationProperties.Name="Copy PID"
                                AutomationProperties.AutomationId="ConsoleCopyPidButton"
                                AutomationProperties.HelpText="Copies the service process ID to the clipboard.">

                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Opacity" Value="0.5" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="1.0" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>

                                <Path
                                    Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z"
                                    Fill="#1B7F9F"
                                    Stretch="Uniform"
                                    Width="12"
                                    Height="12" />
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel
                    Orientation="Horizontal"
                    Grid.Row="0"
                    Grid.Column="2"
                    VerticalAlignment="Center">

                    <Button
                        Command="{Binding ClearSelectionCommand}"
                        Visibility="{Binding IsPaused, Converter={StaticResource BoolToVisibility}}"
                        Margin="0,0,0,6"
                        Padding="8,2"
                        Foreground="White"
                        Content="{x:Static resx:Strings.Button_Resume}"
                        ToolTip="{x:Static resx:Strings.Tooltip_Resume}"
                        Cursor="Hand"
                        AutomationProperties.Name="Resume Scrolling"
                        AutomationProperties.AutomationId="ResumeScrollButton"
                        AutomationProperties.HelpText="Resumes automatic scrolling to the latest log entry.">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#1B7F9F" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border
                                                x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                BorderThickness="0"
                                                CornerRadius="3"
                                                Padding="{TemplateBinding Padding}">

                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#25A2C9" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#146078" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="4"
                    Text="{x:Static resx:Strings.Console_Info}"
                    FontSize="11"
                    Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right"
                    Margin="0,0,0,6"
                    AutomationProperties.Name="Console Instructions" />
            </Grid>

            <Grid Grid.Row="1" Background="#121212">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Background="#2D2D2D" Padding="5">
                    <DockPanel>
                        <TextBlock
                            Text="🔍 Filter:"
                            Foreground="Gray"
                            VerticalAlignment="Center"
                            Margin="5,0" />

                        <TextBox
                            Text="{Binding ConsoleSearchText, UpdateSourceTrigger=PropertyChanged}"
                            Background="#3C3C3C"
                            Foreground="White"
                            BorderThickness="0"
                            Padding="3"
                            AutomationProperties.Name="Log Filter"
                            AutomationProperties.AutomationId="ConsoleFilterTextBox"
                            AutomationProperties.HelpText="Enter text to filter the visible log lines." />
                    </DockPanel>
                </Border>

                <ListBox
                    x:Name="LogList"
                    Grid.Row="1"
                    ItemsSource="{Binding VisibleLines}"
                    Background="Black"
                    BorderThickness="0"
                    SelectionMode="Extended"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                    VirtualizingStackPanel.IsVirtualizing="True"
                    VirtualizingStackPanel.VirtualizationMode="Standard"
                    PreviewKeyDown="LogList_PreviewKeyDown"
                    SelectedIndex="-1"
                    IsSynchronizedWithCurrentItem="False"
                    ScrollViewer.ScrollChanged="LogList_ScrollChanged"
                    AutomationProperties.Name="Log Terminal"
                    AutomationProperties.AutomationId="ConsoleLogList"
                    AutomationProperties.HelpText="Displays scrolling log output. Use context menu to copy selected lines.">

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="#DDDDDD" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />

                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>

                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Type}" Value="{x:Static models:LogType.StdErr}">
                                    <Setter Property="Background" Value="#600000" />
                                    <Setter Property="Foreground" Value="White" />
                                </DataTrigger>

                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#264F78" />
                                </Trigger>

                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True" />
                                        <Condition Property="IsSelected" Value="False" />
                                    </MultiTrigger.Conditions>
                                    <Setter Property="Background" Value="#1E1E1E" />
                                </MultiTrigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem
                                Header="{x:Static resx:Strings.Label_Copy}"
                                Click="CopyMenuItem_Click"
                                AutomationProperties.Name="Copy Selection"
                                AutomationProperties.AutomationId="CopyLogMenuItem" />
                        </ContextMenu>
                    </ListBox.ContextMenu>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock
                                Text="{Binding Text}"
                                FontFamily="Consolas"
                                FontSize="12"
                                TextWrapping="Wrap"
                                Padding="4,0"
                                Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </Grid>
</UserControl>