<Window x:Class="Servy.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Servy"
        xmlns:resx="clr-namespace:Servy.Resources"
        xmlns:viewmodels="clr-namespace:Servy.ViewModels"
        xmlns:converters="clr-namespace:Servy.UI.Converters;assembly=Servy.UI"
        xmlns:helpers="clr-namespace:Servy.Helpers"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        Title="Servy"
        MinWidth="640"
        MinHeight="760"
        SizeToContent="WidthAndHeight"
        ResizeMode="CanMinimize"
        AutomationProperties.Name="Servy Configuration Window"
        AutomationProperties.AutomationId="ConfigMainWindow"
        AutomationProperties.HelpText="Main window for creating and configuring a Servy Windows service."
        >
    <Window.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
    </Window.Resources>
    <DockPanel>

        <Menu DockPanel.Dock="Top" Height="28"
              AutomationProperties.Name="Main Menu"
              AutomationProperties.AutomationId="MainMenu"
              AutomationProperties.HelpText="Application menu for exporting, importing, and help options.">

            <MenuItem Header="{x:Static resx:Strings.Menu_Export}"
                      AutomationProperties.Name="{x:Static resx:Strings.Menu_Export}"
                      AutomationProperties.AutomationId="MenuExport"
                      AutomationProperties.HelpText="Export service configuration menu.">
                <MenuItem Header="{x:Static resx:Strings.Menu_ExportXml}" Command="{Binding ExportXmlCommand}"
                          AutomationProperties.Name="{x:Static resx:Strings.Menu_ExportXml}"
                          AutomationProperties.AutomationId="MenuExportXml"
                          AutomationProperties.HelpText="Export configuration to an XML file."/>
                <MenuItem Header="{x:Static resx:Strings.Menu_ExportJson}" Command="{Binding ExportJsonCommand}"
                          AutomationProperties.Name="{x:Static resx:Strings.Menu_ExportJson}"
                          AutomationProperties.AutomationId="MenuExportJson"
                          AutomationProperties.HelpText="Export configuration to a JSON file."/>
            </MenuItem>

            <MenuItem Header="{x:Static resx:Strings.Menu_Import}"
                      AutomationProperties.Name="{x:Static resx:Strings.Menu_Import}"
                      AutomationProperties.AutomationId="MenuImport"
                      AutomationProperties.HelpText="Import service configuration menu.">
                <MenuItem Header="{x:Static resx:Strings.Menu_ImportXml}" Command="{Binding ImportXmlCommand}"
                          AutomationProperties.Name="{x:Static resx:Strings.Menu_ImportXml}"
                          AutomationProperties.AutomationId="MenuImportXml"
                          AutomationProperties.HelpText="Import configuration from an XML file."/>
                <MenuItem Header="{x:Static resx:Strings.Menu_ImportJson}" Command="{Binding ImportJsonCommand}"
                          AutomationProperties.Name="{x:Static resx:Strings.Menu_ImportJson}"
                          AutomationProperties.AutomationId="MenuImportJson"
                          AutomationProperties.HelpText="Import configuration from a JSON file."/>
            </MenuItem>

            <MenuItem Header="{x:Static resx:Strings.Menu_Manager}" Command="{Binding ManagerCommand}" IsEnabled="{Binding IsManagerAppAvailable}"
                      AutomationProperties.Name="{x:Static resx:Strings.Menu_Manager}"
                      AutomationProperties.AutomationId="MenuManager"
                      AutomationProperties.HelpText="Open the Servy Manager application."/>

            <MenuItem Header="{x:Static resx:Strings.Menu_ClearAll}" Command="{Binding ClearFormCommand}"
                      AutomationProperties.Name="{x:Static resx:Strings.Menu_ClearAll}"
                      AutomationProperties.AutomationId="MenuClearAll"
                      AutomationProperties.HelpText="Clear all fields in the configuration form."/>

            <MenuItem Header="{x:Static resx:Strings.Menu_Help}"
                      AutomationProperties.Name="{x:Static resx:Strings.Menu_Help}"
                      AutomationProperties.AutomationId="MenuHelp"
                      AutomationProperties.HelpText="Help and documentation menu.">
                <MenuItem Header="{x:Static resx:Strings.Menu_Doc}" Command="{Binding OpenDocumentationCommand}"
                          AutomationProperties.Name="{x:Static resx:Strings.Menu_Doc}"
                          AutomationProperties.AutomationId="MenuDoc"
                          AutomationProperties.HelpText="Open the official Servy documentation."/>
                <MenuItem Header="{x:Static resx:Strings.Menu_CheckUpdates}" Command="{Binding CheckUpdatesCommand}"
                          AutomationProperties.Name="{x:Static resx:Strings.Menu_CheckUpdates}"
                          AutomationProperties.AutomationId="MenuCheckUpdates"
                          AutomationProperties.HelpText="Check online for application updates."/>
                <MenuItem Header="{x:Static resx:Strings.Menu_About}" Command="{Binding OpenAboutDialogCommand}"
                          AutomationProperties.Name="{x:Static resx:Strings.Menu_About}"
                          AutomationProperties.AutomationId="MenuAbout"
                          AutomationProperties.HelpText="Show information about the Servy application."/>
            </MenuItem>
        </Menu>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TabControl Grid.Row="0"
                        AutomationProperties.Name="Configuration Tabs"
                        AutomationProperties.AutomationId="ConfigurationTabControl"
                        AutomationProperties.HelpText="Navigate between different configuration sections for the service.">

                <TabItem Header="{x:Static resx:Strings.Label_MainTab}"
                         AutomationProperties.Name="{x:Static resx:Strings.Label_MainTab}"
                         AutomationProperties.AutomationId="TabItemMain"
                         AutomationProperties.HelpText="General configuration options for the service.">
                    <Grid Margin="20" HorizontalAlignment="Center" VerticalAlignment="Top" MinHeight="520">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="340"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static resx:Strings.Label_ServiceName}" Margin="0,5,10,5"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" 
                                 Margin="0,5"
                                 Text="{Binding ServiceName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="22" MinHeight="22" MaxHeight="22" MaxLines="1" 
                                 TextWrapping="NoWrap" AcceptsReturn="False"
                                 HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                                 VerticalContentAlignment="Center"
                                 AutomationProperties.Name="{x:Static resx:Strings.Label_ServiceName}"
                                 AutomationProperties.AutomationId="TextBoxServiceName"
                                 AutomationProperties.HelpText="Enter the system name of the service."/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static resx:Strings.Label_ServiceDisplayName}" Margin="0,5,10,5"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                 Margin="0,5"
                                 Text="{Binding ServiceDisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="22" MinHeight="22" MaxHeight="22" MaxLines="1" 
                                 TextWrapping="NoWrap" AcceptsReturn="False"
                                 HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                                 VerticalContentAlignment="Center"
                                 AutomationProperties.Name="{x:Static resx:Strings.Label_ServiceDisplayName}"
                                 AutomationProperties.AutomationId="TextBoxServiceDisplayName"
                                 AutomationProperties.HelpText="Enter the display name of the service."/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                   Text="{x:Static resx:Strings.Info_ServiceDisplayName}" 
                                   FontStyle="Normal" 
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static resx:Strings.Label_ServiceDescription}" Margin="0,5,10,5"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                                 Margin="0,5"
                                 Text="{Binding ServiceDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="22" MinHeight="22" MaxHeight="22" MaxLines="1" 
                                 TextWrapping="NoWrap" AcceptsReturn="False"
                                 HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                                 VerticalContentAlignment="Center"
                                 AutomationProperties.Name="{x:Static resx:Strings.Label_ServiceDescription}"
                                 AutomationProperties.AutomationId="TextBoxServiceDescription"
                                 AutomationProperties.HelpText="Enter the description of the service."/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="{x:Static resx:Strings.Label_ProcessPath}" Margin="0,5,10,5"/>
                        <TextBox Grid.Row="4" Grid.Column="1" 
                                 Margin="0,5"
                                 Text="{Binding ProcessPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="22" MinHeight="22" MaxHeight="22" MaxLines="1" 
                                 TextWrapping="NoWrap" AcceptsReturn="False"
                                 HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                                 VerticalContentAlignment="Center"
                                 AutomationProperties.Name="{x:Static resx:Strings.Label_ProcessPath}"
                                 AutomationProperties.AutomationId="TextBoxProcessPath"
                                 AutomationProperties.HelpText="Enter the executable path for the service."/>
                        <Button Grid.Row="4" Grid.Column="2" Content="{x:Static resx:Strings.Button_Browse}" Command="{Binding BrowseProcessPathCommand}" Margin="5,5,0,5"
                                AutomationProperties.Name="Browse Process Path"
                                AutomationProperties.AutomationId="ButtonBrowseProcessPath"
                                AutomationProperties.HelpText="Browse to select the executable process path."/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2"
                                   Text="{x:Static resx:Strings.Info_ProcessPath}" 
                                   FontStyle="Normal" 
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="{x:Static resx:Strings.Label_StartupDirectory}" Margin="0,5,10,5"/>
                        <TextBox Grid.Row="6" Grid.Column="1" 
                                 Margin="0,5"
                                 Text="{Binding StartupDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="22" MinHeight="22" MaxHeight="22" MaxLines="1" 
                                 TextWrapping="NoWrap" AcceptsReturn="False"
                                 HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                                 VerticalContentAlignment="Center"
                                 AutomationProperties.Name="{x:Static resx:Strings.Label_StartupDirectory}"
                                 AutomationProperties.AutomationId="TextBoxStartupDirectory"
                                 AutomationProperties.HelpText="Enter the startup working directory."/>
                        <Button Grid.Row="6" Grid.Column="2" Content="{x:Static resx:Strings.Button_Browse}" Command="{Binding BrowseStartupDirectoryCommand}" Margin="5,5,0,5"
                                AutomationProperties.Name="Browse Startup Directory"
                                AutomationProperties.AutomationId="ButtonBrowseStartupDirectory"
                                AutomationProperties.HelpText="Browse to select the startup directory."/>
                        <TextBlock Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2"
                                   Text="{x:Static resx:Strings.Info_StartupDirectory}" 
                                   FontStyle="Normal" 
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="{x:Static resx:Strings.Label_ProcessParameters}" Margin="0,5,10,5"/>
                        <TextBox Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,5" 
                                 Text="{Binding ProcessParameters, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="False" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="80"
                                 AutomationProperties.Name="{x:Static resx:Strings.Label_ProcessParameters}"
                                 AutomationProperties.AutomationId="TextBoxProcessParameters"
                                 AutomationProperties.HelpText="Enter the command line parameters for the process."/>
                        <TextBlock Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="2"
                                   Text="{x:Static resx:Strings.Info_ProcessParameters}" 
                                   FontStyle="Normal" 
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="10" Grid.Column="0" Text="{x:Static resx:Strings.Label_StartupType}" Margin="0,5,10,5"/>
                        <ComboBox Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="2"
                                  Margin="0,5" 
                                  ItemsSource="{Binding StartupTypes}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValue="{Binding SelectedStartupType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="StartupType"
                                  AutomationProperties.Name="{x:Static resx:Strings.Label_StartupType}"
                                  AutomationProperties.AutomationId="ComboBoxStartupType"
                                  AutomationProperties.HelpText="Select the service startup type."/>

                        <TextBlock Grid.Row="11" Grid.Column="0" Text="{x:Static resx:Strings.Label_ProcessPriority}" Margin="0,5,10,5"/>
                        <ComboBox Grid.Row="11" Grid.Column="1" Grid.ColumnSpan="2"
                                  Margin="0,5" 
                                  ItemsSource="{Binding ProcessPriorities}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValue="{Binding SelectedProcessPriority, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Priority"
                                  AutomationProperties.Name="{x:Static resx:Strings.Label_ProcessPriority}"
                                  AutomationProperties.AutomationId="ComboBoxProcessPriority"
                                  AutomationProperties.HelpText="Select the process priority level."/>

                        <TextBlock Grid.Row="12" Grid.Column="0" Text="{x:Static resx:Strings.Label_StartTimeout}" Margin="0,5,10,5"/>
                        <TextBox Grid.Row="12" Grid.Column="1" Grid.ColumnSpan="2"
                                 Margin="0,5"
                                 Text="{Binding StartTimeout, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="22" MinHeight="22" MaxHeight="22" MaxLines="1" 
                                 TextWrapping="NoWrap" AcceptsReturn="False"
                                 HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                                 VerticalContentAlignment="Center"
                                 AutomationProperties.Name="{x:Static resx:Strings.Label_StartTimeout}"
                                 AutomationProperties.AutomationId="TextBoxStartTimeout"
                                 AutomationProperties.HelpText="Enter the timeout in seconds for starting the service."/>
                        <TextBlock Grid.Row="13" Grid.Column="1" Grid.ColumnSpan="2"
                                   Text="{x:Static resx:Strings.Info_StartTimeout}" 
                                   FontStyle="Normal" 
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="14" Grid.Column="0" Text="{x:Static resx:Strings.Label_StopTimeout}" Margin="0,5,10,5"/>
                        <TextBox Grid.Row="14" Grid.Column="1" Grid.ColumnSpan="2"
                                 Margin="0,5"
                                 Text="{Binding StopTimeout, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="22" MinHeight="22" MaxHeight="22" MaxLines="1" 
                                 TextWrapping="NoWrap" AcceptsReturn="False"
                                 HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                                 VerticalContentAlignment="Center"
                                 AutomationProperties.Name="{x:Static resx:Strings.Label_StopTimeout}"
                                 AutomationProperties.AutomationId="TextBoxStopTimeout"
                                 AutomationProperties.HelpText="Enter the timeout in seconds for stopping the service."/>
                        <TextBlock Grid.Row="15" Grid.Column="1" Grid.ColumnSpan="2"
                                   Text="{x:Static resx:Strings.Info_StopTimeout}" 
                                   FontStyle="Normal" 
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   TextWrapping="Wrap"/>
                        <CheckBox Grid.Row="16" Grid.Column="1" Grid.ColumnSpan="2"
                                  IsChecked="{Binding EnableConsoleUI, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,10"
                                  AutomationProperties.Name="{x:Static resx:Strings.Label_EnableConsoleUI}"
                                  AutomationProperties.AutomationId="CheckBoxEnableConsoleUI"
                                  AutomationProperties.HelpText="Check to enable console UI support.">
                            <CheckBox.Content>
                                <TextBlock Text="{x:Static resx:Strings.Label_EnableConsoleUI}" TextWrapping="Wrap" />
                            </CheckBox.Content>
                        </CheckBox>
                    </Grid>
                </TabItem>

                <TabItem Header="{x:Static resx:Strings.Label_LoggingTab}"
                         AutomationProperties.Name="{x:Static resx:Strings.Label_LoggingTab}"
                         AutomationProperties.AutomationId="TabItemLogging"
                         AutomationProperties.HelpText="Configure standard output and error logging settings.">
                    <Grid Margin="20" HorizontalAlignment="Center" VerticalAlignment="Top" MinHeight="520">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="340"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static resx:Strings.Label_StdoutPath}" Margin="0,5,10,5"/>
                        <TextBox Grid.Row="0" Grid.Column="1" 
                                 Margin="0,5"
                                 Text="{Binding StdoutPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="22" MinHeight="22" MaxHeight="22" MaxLines="1" 
                                 TextWrapping="NoWrap" AcceptsReturn="False"
                                 HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                                 VerticalContentAlignment="Center"
                                 AutomationProperties.Name="{x:Static resx:Strings.Label_StdoutPath}"
                                 AutomationProperties.AutomationId="TextBoxStdoutPath"
                                 AutomationProperties.HelpText="Enter the path for the standard output log file."/>
                        <Button Grid.Row="0" Grid.Column="2" Content="{x:Static resx:Strings.Button_Browse}" Command="{Binding BrowseStdoutPathCommand}" Margin="5,5,0,5"
                                AutomationProperties.Name="Browse Standard Output Path"
                                AutomationProperties.AutomationId="ButtonBrowseStdout"
                                AutomationProperties.HelpText="Browse to select the standard output log file."/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static resx:Strings.Label_StderrPath}" Margin="0,5,10,5"/>
                        <TextBox Grid.Row="1" Grid.Column="1" 
                                 Margin="0,5"
                                 Text="{Binding StderrPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="22" MinHeight="22" MaxHeight="22" MaxLines="1" 
                                 TextWrapping="NoWrap" AcceptsReturn="False"
                                 HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                                 VerticalContentAlignment="Center"
                                 AutomationProperties.Name="{x:Static resx:Strings.Label_StderrPath}"
                                 AutomationProperties.AutomationId="TextBoxStderrPath"
                                 AutomationProperties.HelpText="Enter the path for the standard error log file."/>
                        <Button Grid.Row="1" Grid.Column="2" Content="{x:Static resx:Strings.Button_Browse}" Command="{Binding BrowseStderrPathCommand}" Margin="5,5,0,5"
                                AutomationProperties.Name="Browse Standard Error Path"
                                AutomationProperties.AutomationId="ButtonBrowseStderr"
                                AutomationProperties.HelpText="Browse to select the standard error log file."/>

                        <CheckBox Grid.Row="2" Grid.Column="1"
                                  Content="{x:Static resx:Strings.Label_EnableSizeRotation}"
                                  IsChecked="{Binding EnableSizeRotation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,5"
                                  AutomationProperties.Name="{x:Static resx:Strings.Label_EnableSizeRotation}"
                                  AutomationProperties.AutomationId="CheckBoxEnableSizeRotation"
                                  AutomationProperties.HelpText="Check to enable log rotation based on file size."/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static resx:Strings.Label_RotationSize}" Margin="0,5,10,5"/>
                        <TextBox Grid.Row="3" Grid.Column="1" 
                                 Margin="0,5"
                                 IsEnabled="{Binding EnableSizeRotation}"
                                 Text="{Binding RotationSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="22" MinHeight="22" MaxHeight="22" MaxLines="1" 
                                 TextWrapping="NoWrap" AcceptsReturn="False"
                                 HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                                 VerticalContentAlignment="Center"
                                 AutomationProperties.Name="{x:Static resx:Strings.Label_RotationSize}"
                                 AutomationProperties.AutomationId="TextBoxRotationSize"
                                 AutomationProperties.HelpText="Enter the maximum log file size before rotation."/>
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="{x:Static resx:Strings.Label_RotationSizeUnity}" VerticalAlignment="Center" Margin="5,5,0,5"/>

                        <CheckBox Grid.Row="4" Grid.Column="1"
                                  Content="{x:Static resx:Strings.Label_EnableDateRotation}"
                                  IsChecked="{Binding EnableDateRotation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,5"
                                  AutomationProperties.Name="{x:Static resx:Strings.Label_EnableDateRotation}"
                                  AutomationProperties.AutomationId="CheckBoxEnableDateRotation"
                                  AutomationProperties.HelpText="Check to enable log rotation based on dates."/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="{x:Static resx:Strings.Label_DateRotationType}" Margin="0,5,10,5"/>
                        <ComboBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" 
                                  Margin="0,5"
                                  ItemsSource="{Binding DateRotationTypes}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValue="{Binding SelectedDateRotationType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="DateRotationType"
                                  IsEnabled="{Binding EnableDateRotation}"
                                  AutomationProperties.Name="{x:Static resx:Strings.Label_DateRotationType}"
                                  AutomationProperties.AutomationId="ComboBoxDateRotationType"
                                  AutomationProperties.HelpText="Select the interval for date-based log rotation."/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2"
                                   Text="{x:Static resx:Strings.Info_DateRotation}" 
                                   FontStyle="Normal" 
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   TextWrapping="Wrap"/>

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="{x:Static resx:Strings.Label_MaxRotations}" Margin="0,5,10,5"/>
                        <TextBox Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" 
                                 Margin="0,5"
                                 IsEnabled="{Binding EnableRotation}"
                                 Text="{Binding MaxRotations, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 Height="22" MinHeight="22" MaxHeight="22" MaxLines="1" 
                                 TextWrapping="NoWrap" AcceptsReturn="False"
                                 HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                                 VerticalContentAlignment="Center"
                                 AutomationProperties.Name="{x:Static resx:Strings.Label_MaxRotations}"
                                 AutomationProperties.AutomationId="TextBoxMaxRotations"
                                 AutomationProperties.HelpText="Enter the maximum number of rotated logs to keep."/>
                        <TextBlock Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2"
                                   Text="{x:Static resx:Strings.Info_MaxRotations}" 
                                   FontStyle="Normal" 
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   TextWrapping="Wrap"/>

                        <CheckBox Grid.Row="9" Grid.Column="1"
                                  Content="{x:Static resx:Strings.Label_UseLocalTimeForRotation}"
                                  IsChecked="{Binding UseLocalTimeForRotation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,5"
                                  AutomationProperties.Name="{x:Static resx:Strings.Label_UseLocalTimeForRotation}"
                                  AutomationProperties.AutomationId="CheckBoxUseLocalTimeForRotation"
                                  AutomationProperties.HelpText="Check to use local time instead of UTC for log rotations."/>

                        <CheckBox Grid.Row="10" Grid.Column="1"
                                  Content="{x:Static resx:Strings.Label_EnableDebugLogs}"
                                  IsChecked="{Binding EnableDebugLogs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,5"
                                  AutomationProperties.Name="{x:Static resx:Strings.Label_EnableDebugLogs}"
                                  AutomationProperties.AutomationId="CheckBoxEnableDebugLogs"
                                  AutomationProperties.HelpText="Check to enable diagnostic debug logging."/>
                        <TextBlock Grid.Row="11" Grid.Column="1" Grid.ColumnSpan="2"
                                   Text="{x:Static resx:Strings.Info_EnableDebugLogs}" 
                                   FontStyle="Normal" 
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                                   TextWrapping="Wrap"/>
                    </Grid>
                </TabItem>

                <TabItem Header="{x:Static resx:Strings.Label_RecoveryTab}"
                         AutomationProperties.Name="{x:Static resx:Strings.Label_RecoveryTab}"
                         AutomationProperties.AutomationId="TabItemRecovery"
                         AutomationProperties.HelpText="Configure automated health checks and recovery actions.">
                    <Grid Margin="20" HorizontalAlignment="Center" VerticalAlignment="Top" MinHeight="520">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="340"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Row="0" 
                                  Grid.Column="1" 
                                  Content="{x:Static resx:Strings.Label_EnableHealthMonitoring}"
                                  IsChecked="{Binding EnableHealthMonitoring, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,5"
                                  AutomationProperties.Name="{x:Static resx:Strings.Label_EnableHealthMonitoring}"
                                  AutomationProperties.AutomationId="CheckBoxEnableHealthMonitoring"
                                  AutomationProperties.HelpText="Check to enable background health monitoring for this service."/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static resx:Strings.Label_HeartbeatInterval}" Margin="0,5,10,5"/>
                        <TextBox Grid.Row="1" Grid.Column="1" 
                                 Margin="0,5"
                                 IsEnabled="{Binding EnableHealthMonitoring}"
