<?xml version="1.0" encoding="utf-8"?>
<ServiceDto xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Name>WexflowServer</Name>
  <DisplayName>WexflowServer</DisplayName>
  <Description>Wexflow Workflow Automation Engine</Description>
  <ExecutablePath>C:\Program Files\dotnet\dotnet.exe</ExecutablePath>
  <StartupDirectory>C:\Program Files\Wexflow Server\Wexflow.Server\</StartupDirectory>
  <Parameters>Wexflow.Server.dll</Parameters>
  <StartupType>3</StartupType>
  <Priority>2</Priority>
  <EnableConsoleUI>false</EnableConsoleUI>
  <StdoutPath>C:\dev\servy\stdout.log</StdoutPath>
  <StderrPath>C:\dev\servy\stderr.log</StderrPath>
  <EnableSizeRotation>false</EnableSizeRotation>
  <RotationSize>10</RotationSize>
  <EnableDateRotation>false</EnableDateRotation>
  <DateRotationType>0</DateRotationType>
  <MaxRotations>0</MaxRotations>
  <UseLocalTimeForRotation>true</UseLocalTimeForRotation>
  <EnableHealthMonitoring>true</EnableHealthMonitoring>
  <HeartbeatInterval>5</HeartbeatInterval>
  <MaxFailedChecks>1</MaxFailedChecks>
  <RecoveryAction>1</RecoveryAction>
  <MaxRestartAttempts>3</MaxRestartAttempts>
  <EnvironmentVariables>var1=val1;var2=val2</EnvironmentVariables>
  <ServiceDependencies>MongoDB</ServiceDependencies>
  <PreLaunchTimeoutSeconds>30</PreLaunchTimeoutSeconds>
  <PreLaunchRetryAttempts>0</PreLaunchRetryAttempts>
  <PreLaunchIgnoreFailure>false</PreLaunchIgnoreFailure>
  <EnableDebugLogs>false</EnableDebugLogs>
  <StartTimeout>10</StartTimeout>
  <StopTimeout>5</StopTimeout>
  <PreStopTimeoutSeconds>5</PreStopTimeoutSeconds>
  <PreStopLogAsError>false</PreStopLogAsError>
</ServiceDto>